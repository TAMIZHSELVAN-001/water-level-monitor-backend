# ════════════════════════════════════════════════════════════
# 🌊 WATER LEVEL MONITOR - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════

# ── Server Configuration ───────────────────────────────────
PORT=3000
NODE_ENV=development
API_KEY=your_secure_api_key_here

# ── PostgreSQL Database ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=water_level2
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Admin Seed (Optional) ──────────────────────────────────
ADMIN_NAME=Super Admin
ADMIN_EMAIL=tamizh2702@gmail.com
ADMIN_PASSWORD=Tamizh@123
ADMIN_MOBILE=8248769293

# ── Email Notifications (Optional) ─────────────────────────
# Get these from https://dashboard.emailjs.com
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key

# ════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Update DB_PASSWORD with your PostgreSQL password
# 3. Set API_KEY and use the same value in Swagger Authorize (x-api-key)
# 4. (Optional) Set ADMIN_* values, then run npm run seed:admin
# 5. (Optional) Add EmailJS credentials for email alerts
# 6. Save the file
# ════════════════════════════════════════════════════════════

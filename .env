# ════════════════════════════════════════════════════════════
# 🌊 WATER LEVEL MONITOR - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════

# ── Server Configuration ───────────────────────────────────
PORT=3000
NODE_ENV=development
API_KEY=dev-api-key

# ── PostgreSQL Database ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=water_level2
DB_USER=postgres
DB_PASSWORD=Password

# ── Admin Account ─────────────────────────────────────────
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@1234
ADMIN_MOBILE=1234567890

# ════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Update DB_PASSWORD with your PostgreSQL password
# 3. (Optional) Add EmailJS credentials for email alerts
# 4. Save the file
# ════════════════════════════════════════════════════════════
